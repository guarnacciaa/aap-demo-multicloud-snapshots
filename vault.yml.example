---
# ============================================================================
# VAULT SECRETS (EXAMPLE)
# ============================================================================
# Copy this file to vault.yml, fill in real values, then encrypt it:
#
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
#
# vault.yml is gitignored and must never be committed to the repository.
#
# This file is organized into two scopes, marked by the banners below:
#   [ALWAYS REQUIRED]  needed in every deployment, regardless of mode.
#   [LAB/DEV ONLY]      consumed exclusively by the Provision - Azure VM /
#                       Deprovision - Azure VM job templates and workflows.
#                       SKIP this section when demo_manage_infrastructure is
#                       false (customer/PoC deployment against a pre-existing
#                       VM) — leaving it at CHANGE_ME is fine, it is simply
#                       never used.
# playbooks/aap_config.yml and playbooks/verify.yml enforce this: the
# [LAB/DEV ONLY] secret is only validated when demo_manage_infrastructure
# is true, so a customer/PoC deployment is never blocked by it.
# ============================================================================

# --- AAP Controller credentials --- [ALWAYS REQUIRED]
controller_username: admin
controller_password: CHANGE_ME

# --- Azure Service Principal --- [ALWAYS REQUIRED]
# Required by the Snapshot - Azure by hostname job template in every
# deployment mode (authenticates the lookup of the target VM by hostname).
vault_azure_client_id: CHANGE_ME
vault_azure_client_secret: CHANGE_ME

# --- Azure VM provisioning --- [LAB/DEV ONLY]
# Consumed exclusively by Provision - Azure VM. Leave at CHANGE_ME when
# demo_manage_infrastructure: false; it is unused.
vault_azure_vm_admin_password: CHANGE_ME

# --- AWS IAM user --- [ALWAYS REQUIRED]
# Required by the Snapshot - AWS by hostname job template in every
# deployment mode (authenticates the lookup of the target instance by tag).
vault_aws_access_key: CHANGE_ME
vault_aws_secret_key: CHANGE_ME
