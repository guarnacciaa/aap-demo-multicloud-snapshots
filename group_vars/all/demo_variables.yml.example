# ============================================================================
# DEMO CONFIGURATION VARIABLES (EXAMPLE)
# ============================================================================
# Copy to demo_variables.yml and edit for your environment.
# demo_variables.yml is gitignored so it is not overwritten on git pull.
#
# This file is organized into two scopes, marked by the banners below:
#   [ALWAYS REQUIRED]  needed in every deployment, regardless of mode.
#   [LAB/DEV ONLY]      consumed exclusively by the Provision - */
#                       Deprovision - * job templates and workflows. SKIP
#                       these entire sections when demo_manage_infrastructure
#                       is false (customer/PoC deployment against pre-existing
#                       infrastructure) — leaving them at their defaults is
#                       fine, they are simply never used.
# playbooks/aap_config.yml and playbooks/verify.yml enforce this: the
# [LAB/DEV ONLY] variables are only validated when demo_manage_infrastructure
# is true, so a customer/PoC deployment is never blocked by them.
# ============================================================================

demo_no_log: false
# Unmask errors from infra.aap_configuration roles (credentials, etc.).
# Set to true in production to hide secrets from job output.
aap_configuration_secure_logging: false

# --- Deployment mode --- [ALWAYS REQUIRED]
# true (default): lab / dev / self-demo deployment. CasC creates the full
#   infrastructure lifecycle: Provision - Azure VM, Provision - AWS EC2,
#   Update - Multicloud inventory hosts, Deprovision - Azure VM,
#   Deprovision - AWS EC2, plus the WF - Demo setup and WF - Demo teardown
#   workflows. Use this when there is no pre-existing cloud infrastructure
#   and you want the demo to create and destroy everything itself. All
#   [LAB/DEV ONLY] variables below must be set.
# false: customer / PoC deployment against pre-existing infrastructure. CasC
#   creates ONLY the snapshot job templates (Snapshot - Azure/AWS by hostname,
#   Snapshot - Verify, Snapshot - Cleanup) and WF - Multicloud snapshot and
#   retention. No provisioning or deprovisioning objects are created in AAP at
#   all, which removes any risk of accidentally launching a job that creates
#   duplicate cloud resources or deletes the customer's existing networking.
#   [LAB/DEV ONLY] variables below can be left at their defaults.
demo_manage_infrastructure: true

# --- AAP connection --- [ALWAYS REQUIRED]
# controller_username and controller_password live in vault.yml.
# The dispatch role resolves gateway auth from aap_* -> controller_* fallback.
aap_hostname: CHANGE_ME
aap_username: "{{ controller_username }}"
aap_password: "{{ controller_password }}"
aap_validate_certs: false

# Controller REST API path prefix when calling through Platform Gateway (AAP 2.5+).
# Do not use legacy /api/v2/ on the gateway hostname.
aap_controller_api_prefix: /api/controller/v2

# --- AAP Bearer token (required for AAP 2.5+ Platform Gateway) --- [ALWAYS REQUIRED if used]
# Username/password auth requires a token request to /api/o/token/, which the
# Platform Gateway does not expose → HTTP 404 on direct ansible.controller calls.
# Generate a personal access token in the AAP UI: User menu → Tokens → Add,
# then store it in vault.yml as vault_aap_token and map it here.
# When aap_token is defined it takes precedence over username/password in all
# ansible.controller module calls (update_inventory_hosts, sync tasks).
# Leave commented out if you are running against an older AAP 2.4 controller
# accessed directly (not through the Platform Gateway).
# aap_token: "{{ vault_aap_token }}"

# --- AAP object names --- [ALWAYS REQUIRED]
demo_organization_name: Multicloud Snapshots Demo
demo_organization_description: Multicloud snapshot and retention PoC
demo_project_name: Multicloud Snapshots Demo
demo_label_name: multicloud-snapshots
demo_inventory_name: Demo-MulticloudSnapshots
# Automation Controller auto-creates this source when kind is constructed (do not rename in the UI).
demo_constructed_inventory_source_name: "Auto-created source for: {{ demo_inventory_name }}"
# Child inventory names — must be unique across artifacts, not the bare
# "Azure-Resources"/"AWS-Resources" shape. ansible.controller.host and
# ansible.controller.group resolve their inventory: parameter by name only,
# with no organization filter (module.resolve_name_to_id), so a same-named
# inventory in another artifact's Organization makes aap_config.yml fail with
# "returned 2 items, expected 1". See artifact--demo-variables.mdc.
demo_azure_inventory_name: Azure-Resources-MulticloudSnapshots
demo_aws_inventory_name: AWS-Resources-MulticloudSnapshots
demo_execution_environment_name: ee-multicloud-snapshots
# Full image reference after building and pushing to Private Automation Hub.
# Must match the tag used in podman push (see docs/setup.md).
demo_execution_environment_image: CHANGE_ME/ee-multicloud-snapshots:latest

# Private Automation Hub container registry (for Controller EE image pulls). [ALWAYS REQUIRED if using a custom EE]
# Use the Gateway host or IP without a URL scheme; must match demo_execution_environment_image.
hub_registry_credential_name: PAH Container Registry - Multicloud Snapshots
hub_registry_host: "{{ aap_hostname | regex_replace('^https?://', '') | regex_replace('/$', '') }}"

# ============================================================================
# Git repository configuration [ALWAYS REQUIRED]
# ============================================================================
# Choose ONE of the following options based on your Git hosting platform:
#
# OPTION A: GitHub
#   demo_project_scm_url: https://github.com/YOUR_USERNAME/aap-demo-multicloud-snapshots.git
#
# OPTION B: Gitea (self-hosted)
#   demo_project_scm_url: https://your-gitea.example.com/YOUR_USERNAME/aap-demo-multicloud-snapshots.git
#
# OPTION C: GitLab
#   demo_project_scm_url: https://gitlab.com/YOUR_USERNAME/aap-demo-multicloud-snapshots.git
# ============================================================================

demo_project_scm_url: CHANGE_ME_GIT_REPO_URL
demo_project_scm_branch: main

# ============================================================================
# Azure — target VM identity and credentials [ALWAYS REQUIRED]
# ============================================================================
# Consumed by the snapshot job templates in every deployment mode. In
# customer/PoC mode (demo_manage_infrastructure: false), azure_resource_group
# and azure_vm_hostname must match the customer's EXISTING VM exactly — the
# snapshot playbook looks it up by these two values and fails if no VM is found.

# Authentication mode for every azure.azcollection task (snapshot, provisioning,
# and teardown playbooks). Two values:
#   service_principal (default): client_id + client_secret + tenant_id
#     (below) are injected via the "Azure Service Principal" AAP credential.
#     Works regardless of where AAP itself is hosted — the correct choice for
#     customer/PoC deployments and the only choice if AAP does not run on Azure.
#   msi: Managed Identity, no client secret stored anywhere. Requires the AAP
#     execution node/EE container that runs the job to itself be an Azure
#     resource (VM, VMSS, AKS node, etc.) with a system- or user-assigned
#     identity enabled and the same RBAC role granted (see docs/setup.md).
#     Playbooks pass auth_source: msi on every azure_rm_* task when this is
#     set; azure_client_id/azure_client_secret are then unused (leave the
#     vault entries at CHANGE_ME).
azure_auth_mode: service_principal

azure_subscription_id: CHANGE_ME
azure_tenant_id: CHANGE_ME
# Only used when azure_auth_mode: service_principal (see above).
azure_client_id: "{{ vault_azure_client_id }}"
azure_client_secret: "{{ vault_azure_client_secret }}"
azure_resource_group: CHANGE_ME
azure_vm_hostname: azure-demo-vm01

# ============================================================================
# Azure — VM provisioning and networking [LAB/DEV ONLY]
# Consumed exclusively by Provision - Azure VM / Deprovision - Azure VM.
# Leave at defaults when demo_manage_infrastructure: false; they are unused.
# ============================================================================

azure_location: eastus
azure_vm_size: Standard_B2s
azure_vm_admin_user: azureuser
azure_vm_admin_password: "{{ vault_azure_vm_admin_password }}"
azure_vm_image:
  publisher: RedHat
  offer: RHEL
  sku: "9_4"
  version: latest
azure_vnet_name: demo-multicloud-vnet
azure_vnet_cidr: "10.0.0.0/16"
azure_subnet_name: demo-multicloud-subnet
azure_subnet_cidr: "10.0.1.0/24"
azure_nsg_name: demo-multicloud-nsg

# ============================================================================
# AWS — target instance identity and credentials [ALWAYS REQUIRED]
# ============================================================================
# Consumed by the snapshot job templates in every deployment mode. In
# customer/PoC mode (demo_manage_infrastructure: false), aws_ec2_hostname must
# match the EXISTING instance's "Name" tag exactly, and aws_region must match
# where it runs — the snapshot playbook filters on tag:Name and fails if no
# running instance is found.

aws_region: us-east-1
aws_access_key: "{{ vault_aws_access_key }}"
aws_secret_key: "{{ vault_aws_secret_key }}"
aws_ec2_hostname: aws-demo-vm01

# ============================================================================
# AWS — instance provisioning and networking [LAB/DEV ONLY]
# Consumed exclusively by Provision - AWS EC2 / Deprovision - AWS EC2.
# Leave at defaults when demo_manage_infrastructure: false; they are unused.
# ============================================================================

aws_instance_type: t3.small
# AMI IDs are region-specific. Find the correct ID for your region at:
# https://access.redhat.com/solutions/15356 or the AWS EC2 console (Images > AMIs).
#
# Example AMIs (verified, replace with the latest for your region):
#   RHEL 9 - us-east-1:  find via AWS CLI or Red Hat Image Builder
#   RHEL 10 - eu-north-1: ami-0754facaaac92a5bb
aws_ami_id: CHANGE_ME
aws_key_pair_name: demo-multicloud-keypair
aws_vpc_name: demo-multicloud-vpc
aws_vpc_cidr: "10.1.0.0/16"
aws_subnet_name: demo-multicloud-subnet
aws_subnet_cidr: "10.1.1.0/24"
aws_sg_name: demo-multicloud-sg

# ============================================================================
# Snapshot policy [ALWAYS REQUIRED]
# ============================================================================

# Set to true to enable the cleanup job template; false prevents any deletion.
enable_snapshot_cleanup: false

snapshot_name_prefix: poc-snapshot

# --- Cleanup mode ---
# Choose ONE of the following retention strategies for the Snapshot - Cleanup job:
#
# OPTION A: Time-based retention (default)
#   Delete snapshots older than snapshot_retention_days days.
#   snapshot_cleanup_mode: time
#   snapshot_retention_days: 30
#
# OPTION B: Count-based retention
#   Keep only the newest snapshot_retention_count snapshots per cloud provider;
#   delete all older ones regardless of age.
#   snapshot_cleanup_mode: count
#   snapshot_retention_count: 1
#
# Override at launch via extra variables in the AAP job template if needed.
snapshot_cleanup_mode: count
snapshot_retention_days: 30
snapshot_retention_count: 1

# ============================================================================
# Credential names (must match credentials.yml) [ALWAYS REQUIRED]
# ============================================================================
# Must be unique across artifacts, not a generic placeholder like "Azure
# Service Principal": job_template's credentials: list resolves each name via
# a name-only Controller API lookup with no organization filter
# (module.resolve_name_to_id), so a same-named credential in another
# artifact's Organization makes aap_config.yml fail with
# "returned 2 items, expected 1". See artifact--demo-variables.mdc.

azure_credential_name: Azure Service Principal - Multicloud Snapshots
aws_credential_name: AWS IAM User - Multicloud Snapshots
